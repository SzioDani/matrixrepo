<?xml version="1.0" encoding="utf-8"?>
<window type="dialog">
    <defaultcontrol always="true">1000</defaultcontrol>
    <controls>
        
        <control type="image">
            <width>1280</width>
            <height>720</height>
            <texture colordiffuse="AA000000">colors/black.png</texture>
        </control>

